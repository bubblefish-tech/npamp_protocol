# Pinned/generated conformance corpus + schema MUST be LF so the SHA-256 pinned in
# PIN.json / MANIFEST.sha256 matches on every platform. (Windows Python writes CRLF; git
# commits LF; a CRLF-based pin drifts the pinned-vector gate in CI.)
test-vectors/v1/conformance-corpus.json text eol=lf
test-vectors/schemas/conformance-corpus.schema.json text eol=lf
harness/runner/corpus/conformance-corpus.json text eol=lf
