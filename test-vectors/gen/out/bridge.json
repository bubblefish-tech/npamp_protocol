  },
  {
    "op": "bridge.correlate",
    "profile": "Standard",
    "tests": [
      {
        "tcId": 1,
        "requirement": "10/5/reply-correlates",
        "comment": "BRIDGE_RESPONSE echoing the request correlation_id correlates",
        "in": {
          "requestFrameType": 256,
          "requestPayload": "0010001401010100040a0b0c0d0a746f6f6c732f63616c6c7b226a736f6e727063223a22322e30222c226964223a312c226d6574686f64223a22746f6f6c732f63616c6c227d",
          "replyFrameType": 257,
          "replyPayload": "0010001401020100040a0b0c0d0a746f6f6c732f63616c6c7b226a736f6e727063223a22322e30222c226964223a312c22726573756c74223a7b226f6b223a747275657d7d"
        },
        "expected": {
          "match": true
        },
        "result": "valid"
      },
      {
        "tcId": 2,
        "requirement": "10/5/reply-different-corr-does-not-correlate",
        "comment": "a reply with a different correlation_id does NOT correlate",
        "in": {
          "requestFrameType": 256,
          "requestPayload": "0010001401010100040a0b0c0d0a746f6f6c732f63616c6c7b226a736f6e727063223a22322e30222c226964223a312c226d6574686f64223a22746f6f6c732f63616c6c227d",
          "replyFrameType": 257,
          "replyPayload": "001000140102010004ffffffff0a746f6f6c732f63616c6c7b226a736f6e727063223a22322e30222c226964223a312c22726573756c74223a7b226f6b223a747275657d7d"
        },
        "expected": {
          "match": false
        },
        "result": "valid"
      },
      {
        "tcId": 3,
        "requirement": "10/5/stream-reply-correlates",
        "comment": "a BRIDGE_STREAM_DATA chunk echoing the correlation_id correlates",
        "in": {
          "requestFrameType": 256,
          "requestPayload": "0010001401010100040a0b0c0d0a746f6f6c732f63616c6c7b226a736f6e727063223a22322e30222c226964223a312c226d6574686f64223a22746f6f6c732f63616c6c227d",
          "replyFrameType": 260,
          "replyPayload": "0010001401050100040a0b0c0d0a746f6f6c732f63616c6c6368756e6b2d30"
        },
        "expected": {
          "match": true
        },
        "result": "valid"
      }
    ]
  }
]
