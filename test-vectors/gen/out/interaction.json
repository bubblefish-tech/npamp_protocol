        "in": {
          "frameType": 256,
          "body": "a30019010001412a0203"
        },
        "result": "valid",
        "expected": {
          "frame_kind": 256,
          "corr": "2a"
        }
      },
      {
        "tcId": 2,
        "requirement": "89/6.2/deterministic-cbor-map",
