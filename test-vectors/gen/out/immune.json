[
  {
    "op": "immune.body.decode",
    "profile": "Standard",
    "tests": [
      {
        "tcId": 1,
        "requirement": "85/6.2/deterministic-cbor-map",
        "comment": "valid IMMUNE_REPORT_REQ: envelope + report_id + anomaly_class + severity",
        "in": {
          "frameType": 256,
          "body": "a500190100014163026a616e6f6d616c792d343203010403"
        },
        "result": "valid",
        "expected": {
          "frame_kind": 256,
          "corr": "63"
        }
      },
      {
        "tcId": 2,
        "requirement": "85/6.2/deterministic-cbor-map",
        "comment": "valid IMMUNE_REPORT_RESULT: envelope + disposition + tracking_id",
        "in": {
          "frameType": 257,
          "body": "a4001901010141630201036574726b2d37"
        },
        "result": "valid",
        "expected": {
          "frame_kind": 257,
          "corr": "63"
        }
      },
      {
        "tcId": 3,
        "requirement": "85/8/deterministic-cbor-map",
        "comment": "valid IMMUNE_ERROR: envelope + code + message",
        "in": {
          "frameType": 258,
          "body": "a400190102014163020103716d616c666f726d65642072657175657374"
        },
        "result": "valid",
        "expected": {
          "frame_kind": 258,
          "corr": "63"
        }
      },
      {
        "tcId": 4,
        "requirement": "85/6.4/deterministic-cbor-map",
        "comment": "valid IMMUNE_GOSSIP_ADVERTISE: envelope + items[gossip_descriptor]",
        "in": {
          "frameType": 192,
          "body": "a30018c00141630281a300429a1c01070303"
        },
        "result": "valid",
        "expected": {
          "frame_kind": 192,
          "corr": "63"
        }
      },
      {
        "tcId": 5,
        "requirement": "85/6.6/deterministic-cbor-map",
        "comment": "valid IMMUNE_GOSSIP_RETRACT: envelope + item_id + version + reason",
        "in": {
          "frameType": 196,
          "body": "a50018c401416302429a1c03080400"
        },
        "result": "valid",
        "expected": {
          "frame_kind": 196,
          "corr": "63"
        }
      },
      {
        "tcId": 6,
        "requirement": "85/4.3/forward-compat-accept-nonneg",
        "comment": "unknown NON-negative key (99) MUST be accepted",
        "in": {
          "frameType": 256,
          "body": "a600190100014163026a616e6f6d616c792d34320301040318636c6675747572652d6669656c64"
        },
        "result": "acceptable",
        "expected": {
          "frame_kind": 256,
          "corr": "63"
        },
        "flags": [
          "ForwardCompat"
        ]
      },
      {
        "tcId": 7,
        "requirement": "85/4.1/non-deterministic-cbor-MUST-reject",
        "comment": "key 0 in non-shortest form (0x18 0x00)",
        "in": {
          "frameType": 256,
          "body": "a1180000"
        },
        "result": "invalid",
        "flags": [
          "MustReject",
          "NonDeterministicCBOR"
        ]
      },
      {
        "tcId": 8,
        "requirement": "85/4.3/unknown-negative-key-MUST-reject",
        "comment": "unknown NEGATIVE integer key (-1)",
        "in": {
          "frameType": 256,
          "body": "a600190100014163026178030104032009"
        },
        "result": "invalid",
        "flags": [
          "MustReject",
          "UnknownNegativeKey"
        ]
      },
      {
        "tcId": 9,
        "requirement": "85/6.2/missing-required-key-MUST-reject",
        "comment": "IMMUNE_REPORT_REQ missing REQUIRED report_id(2)",
