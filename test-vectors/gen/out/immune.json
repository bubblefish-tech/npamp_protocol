          "frameType": 256,
          "body": "a40019010001416303010403"
        },
        "result": "invalid",
        "flags": [
          "MustReject",
          "MissingRequiredKey"
        ]
      },
      {
        "tcId": 10,
        "requirement": "85/6.2/wrong-major-type-MUST-reject",
        "comment": "anomaly_class(3) is text where an unsigned int is required",
        "in": {
          "frameType": 256,
          "body": "a50019010001416302617803636261640403"
        },
        "result": "invalid",
        "flags": [
          "MustReject",
          "WrongMajorType"
        ]
      },
      {
